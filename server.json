{
	"$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
	"name": "io.github.devkindhq/machship",
	"title": "Machship MCP",
	"description": "Model Context Protocol server for the Machship freight management platform",
	"repository": {
		"url": "https://github.com/devkindhq/machship-mcp",
		"source": "github"
	},
	"version": "1.0.0",
	"packages": [
		{
			"registryType": "npm",
			"registryBaseUrl": "https://registry.npmjs.org",
			"identifier": "machship-mcp",
			"version": "1.0.0",
			"runtimeHint": "npx",
			"transport": {
				"type": "stdio"
			},
			"environmentVariables": [
				{
					"name": "MACHSHIP_API_TOKEN",
					"description": "Your Machship Bearer token (Settings → API → Generate token)",
					"isRequired": true,
					"isSecret": true
				},
				{
					"name": "MACHSHIP_API_URL",
					"description": "Override the Machship API base URL (default: https://live.machship.com)",
					"isRequired": false,
					"isSecret": false
				}
			]
		}
	],
